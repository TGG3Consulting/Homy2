# ============================================
# HomLy Docker Ignore
# Excludes files from Docker build context
# ============================================

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build outputs (we rebuild in Docker)
.next
out

# TypeScript build outputs
dist
*.tsbuildinfo

# Environment files (NEVER include in images)
.env
.env.*
!.env.example

# Git
.git
.gitignore
.gitattributes

# IDE and editors
.idea
.vscode
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
*.log

# Testing
coverage
.nyc_output
jest.config.js
*.test.ts
*.spec.ts
__tests__
cypress
playwright

# Documentation
docs
*.md
!README.md
LICENSE

# Docker files (avoid recursion)
docker-compose*.yml
Dockerfile*
.dockerignore

# Development tools
.husky
.eslintcache
.prettierignore
prettier.config.js
eslint.config.mjs

# Misc
*.tgz
*.tar.gz
*.zip

# Local development
.claude
.turbo
.vercel

# Debug
npm-debug.log
yarn-debug.log
yarn-error.log

# Prisma (keep schema, exclude migrations for dev)
# prisma/migrations

# Storybook
.storybook
storybook-static

# Build artifacts
build
tmp
temp
