[Unit]
Description=Homy Real Estate AI Assistant
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/homy
ExecStart=/usr/bin/node dist/server.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production
Environment=PORT=3000

# Claude CLI needs these
Environment=HOME=/home/ubuntu
Environment=PATH=/usr/bin:/usr/local/bin:/home/ubuntu/.npm-global/bin

[Install]
WantedBy=multi-user.target
