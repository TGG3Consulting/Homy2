# Homy — Environment Variables (development template)
# Copy to .env and fill in. .env is gitignored — never commit real values.

# Server port (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV=development

# Public base URL (used to build links in emails/notifications)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Serve over HTTPS? Auth cookies are Secure in production regardless.
HTTPS_ENABLED=false

# --- Database (required) ---
DATABASE_URL="postgresql://user:password@localhost:5433/homy?schema=public"

# --- JWT Authentication (required — app fails fast without these) ---
# Generate each separately: openssl rand -base64 64
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# --- Scheduled jobs ---
# Required in production (cron endpoints return 503 without it); callers send it
# as the `x-cron-secret` header. Optional in development.
CRON_SECRET="generate-with-openssl-rand-hex-32"

# --- Email/SMTP (password reset + OTP). Without it, reset emails don't send;
# the admin panel still surfaces a one-time reset link as a fallback. ---
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS="password"
EMAIL_FROM="noreply@homy.am"

# --- Anthropic Claude API (AI search / chat / property opinions) ---
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"

# --- Seeding (dev only) ---
# Password given to seeded demo accounts. The seed refuses to run when
# NODE_ENV=production unless ALLOW_PROD_SEED=true.
SEED_PASSWORD="devpassword123"
# ALLOW_PROD_SEED=false
