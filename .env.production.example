# ============================================
# Homy Production Environment Variables
# IMPORTANT: Never commit actual values to version control
# ============================================

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Database
DATABASE_URL=postgresql://user:password@host:5432/homy_prod?schema=public&sslmode=require
POSTGRES_USER=homy_prod
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=homy_prod

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# Authentication (generate with: openssl rand -base64 32)
JWT_SECRET=GENERATE_WITH_openssl_rand_base64_32
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32

# Email (Production SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=YOUR_SENDGRID_API_KEY
SMTP_FROM=noreply@your-domain.com

# Optional: Disable image optimization if using CDN
DISABLE_IMAGE_OPTIMIZATION=false

# Monitoring (optional)
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
