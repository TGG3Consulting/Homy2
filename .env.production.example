# ============================================
# Homy — Production Environment Variables
# Copy to .env (never commit real values — .env is gitignored)
# Every variable below is actually read by the code. Nothing here is decorative.
# ============================================

# --- Application ---
NODE_ENV=production
PORT=3000
# Public base URL (used to build links in emails/notifications)
NEXT_PUBLIC_APP_URL=https://your-domain.com
# Set true when serving over HTTPS (auth cookies are Secure in production regardless)
HTTPS_ENABLED=true

# --- Database (required) ---
DATABASE_URL=postgresql://user:STRONG_PASSWORD@host:5432/homy_prod?schema=public&sslmode=require

# --- Authentication (REQUIRED — the app fails fast without these) ---
# Generate each SEPARATELY: openssl rand -base64 64
# Missing => server refuses to start. Weak/shared => forgeable tokens.
JWT_SECRET=GENERATE_WITH__openssl_rand_base64_64
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_ONE__openssl_rand_base64_64

# --- Scheduled jobs (REQUIRED in production) ---
# Cron endpoints refuse to run in production unless this is set; callers must send
# it as the `x-cron-secret` header. Without it: viewings never auto-complete and
# saved-search notifications never fire.
# Generate: openssl rand -hex 32
CRON_SECRET=GENERATE_WITH__openssl_rand_hex_32

# --- AI (required for search / chat / property opinions) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Email / SMTP (required for password reset + OTP) ---
# Names must match exactly: the code reads SMTP_PASS and EMAIL_FROM.
# Without working SMTP, reset emails silently fail (the admin panel still shows a
# one-time reset link as a fallback).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=YOUR_SMTP_PASSWORD_OR_API_KEY
EMAIL_FROM=noreply@your-domain.com

# --- Seeding (leave unset in production) ---
# The seed refuses to run when NODE_ENV=production unless ALLOW_PROD_SEED=true.
# SEED_PASSWORD is the password given to seeded demo accounts (dev only).
# ALLOW_PROD_SEED=false
# SEED_PASSWORD=

# ============================================
# docker-compose only (not read by application code)
# ============================================
POSTGRES_USER=homy_prod
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=homy_prod
# Redis is provisioned by compose but currently unused by the app code.
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
